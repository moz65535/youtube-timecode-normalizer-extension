{
  "manifest_version": 3,
  "name": "YouTube Timecode Normalizer",
  "version": "0.1.0",
  "description": "Normalize YouTube video timecode URLs to t=seconds from the context menu and popup.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "clipboardWrite",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "normalizer.js",
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "YouTube Timecode Normalizer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "normalizer.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-timecode-normalizer@moz65535",
      "strict_min_version": "121.0"
    }
  }
}
